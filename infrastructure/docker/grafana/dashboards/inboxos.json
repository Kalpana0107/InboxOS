{
  "title": "InboxOS Monitoring",
  "uid": "inboxos_main",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Email Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(emails_processed_total[5m])", "legendFormat": "Processed Emails/sec", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "AI API Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(ai_api_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(ai_api_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.50, sum(rate(ai_api_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "C" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "Rule Evaluation Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(rule_evaluation_duration_seconds_sum[5m]) / rate(rule_evaluation_duration_seconds_count[5m])", "legendFormat": "Avg Duration", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Notification Delivery Status",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(notification_delivery_total{status='success'}[5m])) by (channel)", "legendFormat": "{{channel}} - Success", "refId": "A" },
        { "expr": "sum(rate(notification_delivery_total{status='failure'}[5m])) by (channel)", "legendFormat": "{{channel}} - Failure", "refId": "B" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [{ "expr": "websocket_active_connections", "legendFormat": "Connections", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "Database Query Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [{ "expr": "rate(db_query_duration_seconds_sum[5m]) / rate(db_query_duration_seconds_count[5m])", "legendFormat": "Avg DB Query Time", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "Used Memory", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "title": "BullMQ Queue Depth",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [{ "expr": "bullmq_queue_depth", "legendFormat": "{{queue}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}
